	<Target Name="CleanDistribution" BeforeTargets="Build">
		<RemoveDir Directories="$(ProjectDir)Distribution/GameData/$(TargetName)/Plugins/" />
		<RemoveDir Directories="$(ProjectDir)Distribution/GameData/$(TargetName)/Textures/" />
		<RemoveDir Directories="$(ProjectDir)Distribution/GameData/$(TargetName)/Web/" />
		<MakeDir Directories="$(ProjectDir)Distribution/GameData/$(TargetName)/Plugins/" />
		<MakeDir Directories="$(ProjectDir)Distribution/GameData/$(TargetName)/Textures/" />
		<MakeDir Directories="$(ProjectDir)Distribution/GameData/$(TargetName)/Web/" />
	</Target>
	<Target Name="CopyToDistribution" AfterTargets="Build">
		<Copy SourceFiles="$(TargetDir)$(TargetFileName)" DestinationFolder="$(ProjectDir)Distribution/GameData/$(TargetName)/Plugins/" />
		<Copy SourceFiles="$(TargetDir)$(TargetName).pdb"
		  DestinationFolder="$(ProjectDir)Distribution/GameData/$(TargetName)/Plugins/"
		  Condition="'$(Configuration)' == 'Debug'" />

		<Copy SourceFiles="$(ProjectDir)Assets/Textures/icon.png"
			  DestinationFolder="$(ProjectDir)Distribution/GameData/$(TargetName)/Textures/"
			  Condition="Exists('$(ProjectDir)Assets/Textures/icon.png')" />

		<Warning Text="Missing icon file: $(ProjectDir)Assets/Textures/icon.png"
				 Condition="!Exists('$(ProjectDir)Assets/Textures/icon.png')" />

		<ItemGroup>
			<WebFiles Include="$(ProjectDir)Assets/Web/**/*" />
		</ItemGroup>

		<Error Text="Missing web folder: $(ProjectDir)Assets/Web/"
			   Condition="!Exists('$(ProjectDir)Assets/Web/')" />

		<Copy SourceFiles="@(WebFiles)"
			  DestinationFiles="@(WebFiles->'$(ProjectDir)Distribution/GameData/$(TargetName)/Web/%(RecursiveDir)%(Filename)%(Extension)')" />

		<Error Text="index.html missing after copy"
			   Condition="!Exists('$(ProjectDir)Distribution/GameData/$(TargetName)/Web/index.html')" />
		<Error Text="viewer.html missing after copy"
			   Condition="!Exists('$(ProjectDir)Distribution/GameData/$(TargetName)/Web/viewer.html')" />
		<Error Text="css/styles.css missing after copy"
			   Condition="!Exists('$(ProjectDir)Distribution/GameData/$(TargetName)/Web/css/styles.css')" />
		<Error Text="js/main.js missing after copy"
			   Condition="!Exists('$(ProjectDir)Distribution/GameData/$(TargetName)/Web/js/main.js')" />
		<Error Text="js/viewer.js missing after copy"
			   Condition="!Exists('$(ProjectDir)Distribution/GameData/$(TargetName)/Web/js/viewer.js')" />
		<Error Text="images/los.png missing after copy"
			   Condition="!Exists('$(ProjectDir)Distribution/GameData/$(TargetName)/Web/images/los.png')" />

		<MakeDir Directories="$(ProjectDir)Distribution/GameData/$(TargetName)/Web/recordings/"
				 Condition="!Exists('$(ProjectDir)Distribution/GameData/$(TargetName)/Web/recordings/')" />

		<Copy SourceFiles="$(ProjectDir)Assets/settings.cfg"
			  DestinationFolder="$(ProjectDir)Distribution/GameData/$(TargetName)/"
			  Condition="Exists('$(ProjectDir)Assets/settings.cfg')" />

		<Warning Text="Missing settings file: $(ProjectDir)Assets/settings.cfg"
				 Condition="!Exists('$(ProjectDir)Assets/settings.cfg')" />
